# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/social_command_center

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS / URLs ─────────────────────────────────────────────────────────────
# FRONTEND_URL: your deployed frontend URL (comma-separated for multiple)
FRONTEND_URL=http://localhost:5173
# API_BASE_URL: this server's public URL (used to build the OAuth redirect URI)
API_BASE_URL=http://localhost:3001

# ─── Security ────────────────────────────────────────────────────────────────
INTERNAL_API_KEY=changeme-strong-random-key
N8N_WEBHOOK_SECRET=changeme-n8n-secret
# TOKEN_ENCRYPTION_KEY: exactly 32+ characters, used to AES-256-GCM encrypt OAuth tokens
TOKEN_ENCRYPTION_KEY=changeme-32-char-encryption-key!!

# ─── Facebook / Meta ─────────────────────────────────────────────────────────
# 1. Go to https://developers.facebook.com → My Apps → Create App
# 2. Add "Facebook Login for Business" product
# 3. Under Facebook Login > Settings, add your OAuth redirect URI:
#    {API_BASE_URL}/api/auth/facebook/callback
# 4. Request permissions: pages_manage_posts, pages_read_engagement, pages_show_list
# 5. Copy your App ID and App Secret below
META_CLIENT_ID=
META_CLIENT_SECRET=

# ─── LinkedIn (future) ───────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── TikTok (future) ─────────────────────────────────────────────────────────
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# ─── S3-compatible Object Storage ────────────────────────────────────────────
# Supports: Cloudflare R2, Backblaze B2, AWS S3
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=social-command-center
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
S3_FORCE_PATH_STYLE=true

# ─── Media Processing ────────────────────────────────────────────────────────
MEDIA_PROCESSING_MODE=self_hosted
IMAGE_PROCESSOR=sharp
VIDEO_PROCESSOR=ffmpeg

# ─── Local AI ────────────────────────────────────────────────────────────────
# Default points to Ollama running locally. Set model and endpoint for your LLM.
LOCAL_AI_ENDPOINT=http://localhost:11434/v1
LOCAL_AI_API_KEY=

# ─── Log level ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
