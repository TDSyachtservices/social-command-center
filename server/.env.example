# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/social_command_center

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS / URLs ────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:3001

# ─── Security ───────────────────────────────────────────────────────────────
INTERNAL_API_KEY=changeme-strong-random-key
N8N_WEBHOOK_SECRET=changeme-n8n-secret
TOKEN_ENCRYPTION_KEY=changeme-32-char-encryption-key!!

# ─── S3-compatible Object Storage ───────────────────────────────────────────
# Supports: Cloudflare R2, Backblaze B2, AWS S3
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=social-command-center
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
S3_FORCE_PATH_STYLE=true

# ─── Media Processing ────────────────────────────────────────────────────────
# Values: self_hosted | cloudinary (cloudinary not implemented)
MEDIA_PROCESSING_MODE=self_hosted
IMAGE_PROCESSOR=sharp
VIDEO_PROCESSOR=ffmpeg

# ─── Local AI ────────────────────────────────────────────────────────────────
LOCAL_AI_ENDPOINT=http://localhost:11434/v1
LOCAL_AI_API_KEY=

# ─── Social Platform OAuth ───────────────────────────────────────────────────
# Not connected yet — placeholder for future OAuth integration
META_CLIENT_ID=
META_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
