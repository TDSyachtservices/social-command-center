generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Platform {
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  TIKTOK
  WEBSITE
  N8N
  LOCAL_AI
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  ARCHIVED
}

enum PlatformPostStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
  SKIPPED
  NEEDS_REVIEW
}

enum ProcessingStatus {
  UPLOADED
  PENDING
  PROCESSING
  READY
  NEEDS_REVIEW
  FAILED
  NEEDS_EXTERNAL_PROCESSING
}

enum ValidationStatus {
  READY
  WARNING
  FAILED
  NEEDS_REVIEW
  NEEDS_EXTERNAL_PROCESSING
}

enum CommentStatus {
  NEW
  REPLIED
  NEEDS_FOLLOW_UP
  RESOLVED
  HIDDEN
  IGNORED
  ESCALATED
  FAILED_REPLY
}

enum CommentPriority {
  LOW
  NORMAL
  HIGH
  URGENT
  SALES_OPPORTUNITY
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts     ScheduledPost[]
  auditLogs AuditLog[]
}

model SocialAccount {
  id                     String    @id @default(cuid())
  platform               Platform
  accountName            String
  accountId              String
  connectionStatus       String    @default("not_connected")
  lastSync               DateTime?
  postingCapability      Boolean   @default(false)
  commentReadCapability  Boolean   @default(false)
  commentReplyCapability Boolean   @default(false)
  moderationCapability   Boolean   @default(false)
  tokenEncrypted         String?
  tokenExpiresAt         DateTime?
  scopes                 String[]
  metadata               Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  postPlatforms  ScheduledPostPlatform[]
  comments       SocialComment[]
  syncLogs       SocialInboxSyncLog[]
  notifications  Notification[]
  platformStats  PlatformStats[]
}

model MediaAsset {
  id                      String           @id @default(cuid())
  originalFileName        String
  originalFileType        String
  originalMimeType        String
  originalSizeBytes       BigInt
  originalWidth           Int?
  originalHeight          Int?
  originalDurationSeconds Float?
  originalStorageKey      String?
  originalPublicUrl       String?
  uploadedBy              String?
  processingStatus        ProcessingStatus @default(UPLOADED)
  qualityScoreLabel       String?
  validationStatus        ValidationStatus @default(NEEDS_REVIEW)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  versions       MediaVersion[]
  processingJobs MediaProcessingJob[]
}

model MediaVersion {
  id                    String           @id @default(cuid())
  mediaAssetId          String
  platform              Platform
  placement             String
  width                 Int
  height                Int
  aspectRatio           String
  format                String
  mimeType              String
  fileSizeBytes         BigInt?
  storageKey            String?
  publicUrl             String?
  processingStatus      ProcessingStatus @default(PENDING)
  cropMode              String           @default("fit")
  focalPointJson        Json?
  safeZoneWarningsJson  Json?
  qualityScore          Float?
  qualityScoreLabel     String?
  qualityScoreReason    String?
  validationStatus      ValidationStatus @default(NEEDS_REVIEW)
  validationErrorsJson  Json?
  validationWarningsJson Json?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  mediaAsset     MediaAsset           @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  processingJobs MediaProcessingJob[]
}

model MediaProcessingJob {
  id             String    @id @default(cuid())
  mediaAssetId   String
  mediaVersionId String?
  jobType        String
  status         String    @default("queued")
  attempts       Int       @default(0)
  errorMessage   String?
  queuedAt       DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  updatedAt      DateTime  @updatedAt

  mediaAsset   MediaAsset    @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  mediaVersion MediaVersion? @relation(fields: [mediaVersionId], references: [id])
}

model ScheduledPost {
  id                   String     @id @default(cuid())
  title                String
  masterCaption        String
  status               PostStatus @default(DRAFT)
  scheduledAt          DateTime?
  publishedAt          DateTime?
  mediaUrl             String?
  mediaType            String?
  postType             String     @default("standard")
  additionalMediaUrls  String[]
  postMetadataJson     Json?
  createdBy            String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  user        User?                   @relation(fields: [createdBy], references: [id])
  platforms   ScheduledPostPlatform[]
  publishLogs PublishLog[]
}

model ScheduledPostPlatform {
  id                  String             @id @default(cuid())
  scheduledPostId     String
  accountId           String?
  platform            Platform
  status              PlatformPostStatus @default(PENDING)
  externalPostId      String?
  platformCaption     String?
  mediaUrl            String?
  mediaType           String?
  additionalMediaUrls String[]
  publishedAt         DateTime?
  errorMessage        String?
  retryCount          Int                @default(0)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  scheduledPost ScheduledPost  @relation(fields: [scheduledPostId], references: [id], onDelete: Cascade)
  account       SocialAccount? @relation(fields: [accountId], references: [id])
}

model PublishLog {
  id              String    @id @default(cuid())
  scheduledPostId String?
  postTitle       String
  platform        Platform
  action          String
  status          String
  externalPostId  String?
  apiResponse     String?
  errorMessage    String?
  timestamp       DateTime  @default(now())

  scheduledPost ScheduledPost? @relation(fields: [scheduledPostId], references: [id])
}

model SocialComment {
  id                  String          @id @default(cuid())
  platform            Platform
  accountId           String?
  accountName         String
  commenterName       String
  commenterHandle     String?
  commentText         String
  originalPostTitle   String?
  originalPostCaption String?
  externalCommentId   String?
  timestamp           DateTime        @default(now())
  status              CommentStatus   @default(NEW)
  priority            CommentPriority @default(NORMAL)
  replyCount          Int             @default(0)
  assignedUser        String?
  mediaUrl            String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  account SocialAccount?       @relation(fields: [accountId], references: [id])
  replies SocialCommentReply[]
  notes   SocialInboxNote[]
}

model SocialCommentReply {
  id              String    @id @default(cuid())
  commentId       String
  replyText       String
  sentBy          String?
  sentAt          DateTime  @default(now())
  status          String    @default("sent")
  externalReplyId String?
  errorMessage    String?

  comment SocialComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model SocialInboxNote {
  id        String   @id @default(cuid())
  commentId String
  noteText  String
  createdBy String?
  createdAt DateTime @default(now())

  comment SocialComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model SocialInboxSyncLog {
  id               String    @id @default(cuid())
  platform         Platform
  accountId        String?
  actionType       String
  status           String
  relatedPost      String?
  relatedCommenter String?
  errorMessage     String?
  timestamp        DateTime  @default(now())

  account SocialAccount? @relation(fields: [accountId], references: [id])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  resourceType String
  resourceId   String?
  details      Json?
  ipAddress    String?
  timestamp    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model Notification {
  id         String   @id @default(cuid())
  platform   String
  accountId  String?
  externalId String?
  type       String
  title      String
  body       String?
  payload    Json?
  isRead     Boolean  @default(false)
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  account SocialAccount? @relation(fields: [accountId], references: [id])

  @@unique([platform, externalId])
  @@index([platform, isRead])
  @@index([createdAt])
}

model PlatformStats {
  id             String   @id @default(cuid())
  platform       String
  accountId      String
  followersCount Int
  polledAt       DateTime @default(now())

  account SocialAccount @relation(fields: [accountId], references: [id])

  @@index([accountId, polledAt])
}

// ─── Hashtag & Mention libraries ──────────────────────────────────────────────
// Reusable hashtag sets and mention contacts/groups surfaced in the composer.

model HashtagSet {
  id        String   @id @default(cuid())
  name      String
  platforms String[] @default([])
  hashtags  String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MentionContact {
  id          String   @id @default(cuid())
  displayName String
  category    String   @default("")
  platforms   String[] @default([])
  handles     Json     @default("{}")
  linkedinUrn String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MentionGroup {
  id         String   @id @default(cuid())
  name       String
  contactIds String[] @default([])
  platforms  String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PostTemplate {
  id                   String   @id @default(cuid())
  name                 String
  description          String?
  postType             String   @default("standard")
  platforms            String[] @default([])
  masterCaption        String   @default("")
  platformCaptionsJson Json?
  hashtagsJson         Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
